//%attributes = {}
var $systemInfo_o : cs:C1710.SystemInfo

$systemInfo_o:=cs:C1710.SystemInfo.me

$systemInfo_o.setParameter(JPPost Hostname; "")
$systemInfo_o.setParameter(JPPost Client ID; "")
$systemInfo_o.setParameter(JPPost Secret Key; "")

$systemInfo_o.setParameter(JPPost Hostname For Test; "")
$systemInfo_o.setParameter(JPPost Client ID For Test; "")
$systemInfo_o.setParameter(JPPost Secret Key For Test; "")

$systemInfo_o.setParameter(JPPost API Version; "v2")
